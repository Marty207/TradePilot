{
  "manifest_version": 3,
  "name": "TradePilot",
  "version": "1.3.2",
  "description": "AI Trader Analyst",

  "permissions": [
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"]
    }
  ]
}