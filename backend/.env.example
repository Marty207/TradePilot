OPENAI_API_KEY=your_openai_api_key_here

# Auth
JWT_SECRET=generate-a-long-random-string
JWT_EXPIRE_DAYS=30
AUTH_REQUIRED=false

# Usage limits
FREE_ANALYSES_PER_MONTH=3
PRO_ANALYSES_PER_MONTH=200

# Stripe (create at https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your public website URL (Vercel, etc.)
WEBSITE_URL=https://trade-pilot-rust.vercel.app

# Optional: persistent DB path on Railway volume
# DATABASE_PATH=/data/tradepilot.db
